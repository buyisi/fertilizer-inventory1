<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>出库管理 - 库存管理系统</title>
  <link rel="stylesheet" href="/css/style.css">
  <script src="https://unpkg.com/@zxing/library@latest"></script>
</head>
<body>
  <header>
    <h1>化肥农药库存管理系统</h1>
  </header>

  <nav>
    <ul>
      <li><a href="/">首页</a></li>
      <li><a href="/stock-in">入库管理</a></li>
      <li><a href="/stock-out" class="active">出库管理</a></li>
      <li><a href="/inventory">库存查询</a></li>
      <li><a href="/expiry-alert">过期提醒</a></li>
    </ul>
  </nav>

  <div class="container">
    <div class="card">
      <h2>产品出库</h2>

      <button id="scanBtn" class="btn btn-scan">📷 扫描条码</button>

      <div id="video-container">
        <video id="video" autoplay></video>
        <button id="stopScanBtn" class="btn btn-danger" style="margin-top: 1rem;">停止扫描</button>
      </div>

      <form id="stockOutForm">
        <div class="form-group">
          <label for="barcode">条码</label>
          <input type="text" id="barcode" name="barcode" required placeholder="扫描或输入条码">
        </div>

        <div class="form-group">
          <label for="name">产品名称</label>
          <input type="text" id="name" name="name" readonly>
        </div>

        <div class="form-group">
          <label for="currentStock">当前库存</label>
          <input type="number" id="currentStock" readonly>
        </div>

        <div class="form-group">
          <label for="quantity">出库数量</label>
          <input type="number" id="quantity" name="quantity" min="1" required value="1">
        </div>

        <button type="submit" class="btn btn-danger">确认出库</button>
      </form>

      <div id="message"></div>
    </div>
  </div>

  <script src="/js/stock-out.js"></script>
</body>
</html>
