<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>入库管理 - 库存管理系统</title>
  <link rel="stylesheet" href="/css/style.css">
  <script src="https://unpkg.com/@zxing/library@latest"></script>
</head>
<body>
  <header>
    <h1>化肥农药库存管理系统</h1>
  </header>

  <nav>
    <ul>
      <li><a href="/">首页</a></li>
      <li><a href="/stock-in" class="active">入库管理</a></li>
      <li><a href="/stock-out">出库管理</a></li>
      <li><a href="/inventory">库存查询</a></li>
      <li><a href="/expiry-alert">过期提醒</a></li>
    </ul>
  </nav>

  <div class="container">
    <div class="card">
      <h2>产品入库</h2>

      <button id="scanBtn" class="btn btn-scan">📷 扫描条码</button>

      <div id="video-container">
        <video id="video" autoplay></video>
        <button id="stopScanBtn" class="btn btn-danger" style="margin-top: 1rem;">停止扫描</button>
      </div>

      <form id="stockInForm">
        <div class="form-group">
          <label for="barcode">条码</label>
          <input type="text" id="barcode" name="barcode" required placeholder="扫描或输入条码">
        </div>

        <div class="form-group">
          <label for="name">产品名称</label>
          <input type="text" id="name" name="name" required>
        </div>

        <div class="form-group">
          <label for="type">产品类型</label>
          <select id="type" name="type" required>
            <option value="化肥">化肥</option>
            <option value="农药">农药</option>
          </select>
        </div>

        <div class="form-group">
          <label for="specification">规格</label>
          <input type="text" id="specification" name="specification">
        </div>

        <div class="form-group">
          <label for="production_date">生产日期</label>
          <input type="date" id="production_date" name="production_date" required>
        </div>

        <div class="form-group">
          <label for="expiry_date">过期日期</label>
          <input type="date" id="expiry_date" name="expiry_date" required>
        </div>

        <div class="form-group">
          <label for="quantity">入库数量</label>
          <input type="number" id="quantity" name="quantity" min="1" required value="1">
        </div>

        <button type="submit" class="btn btn-success">确认入库</button>
      </form>

      <div id="message"></div>
    </div>
  </div>

  <script src="/js/stock-in.js"></script>
</body>
</html>
